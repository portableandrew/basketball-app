{
  "expo": {
    "name": "Bucket Tracker",
    "slug": "bucket-tracker",
    "version": "1.0.0",
    "description": "Track basketball shooting workouts, streaks, and progression.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "bucket-tracker",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buckettracker.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.buckettracker.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Bucket Tracker",
      "shortName": "BucketTracker",
      "themeColor": "#39FF14",
      "backgroundColor": "#0B0F14"
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
